{
  "datasets": [
    {
      "name": "5286acdd",
      "displayName": "Analisis Diario Promedio",
      "queryLines": [
        "USE CATALOG `openaq`;\n",
        "USE SCHEMA `livestreamdata`;\n",
        "\n",
        "SELECT \n",
        "    city, \n",
        "    parameter, \n",
        "    date, \n",
        "    avg_value,\n",
        "    max_value\n",
        "FROM openaq.livestreamdata.gold_daily_summary \n",
        "WHERE parameter IN ('pm25', 'co', 'no2')\n",
        "ORDER BY date DESC, avg_value DESC;"
      ]
    },
    {
      "name": "0d74f282",
      "displayName": "SF",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT \n",
        "    hour,\n",
        "    parameter,\n",
        "    max_gas_level,\n",
        "    avg_gas_level,\n",
        "    status\n",
        "FROM openaq.livestreamdata.gold_sf_gas_anomalies\n",
        "\n",
        "ORDER BY hour DESC\n",
        "LIMIT 100;"
      ]
    },
    {
      "name": "ca93856c",
